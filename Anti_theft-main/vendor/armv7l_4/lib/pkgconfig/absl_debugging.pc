prefix=/g/fruct/auroraos-tensorflow/vendor/armv7l
exec_prefix=${prefix}
libdir=/g/fruct/auroraos-tensorflow/vendor/armv7l/lib
includedir=/g/fruct/auroraos-tensorflow/vendor/armv7l/include

Name: absl_debugging
Description: Abseil debugging library
URL: https://abseil.io/
Version: 20230802
Requires: absl_stacktrace = 20230802, absl_leak_check = 20230802
Libs: -L${libdir}  
Cflags: -I${includedir} -DNOMINMAX

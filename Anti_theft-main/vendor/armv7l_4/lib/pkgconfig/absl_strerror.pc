prefix=/g/fruct/auroraos-tensorflow/vendor/armv7l
exec_prefix=${prefix}
libdir=/g/fruct/auroraos-tensorflow/vendor/armv7l/lib
includedir=/g/fruct/auroraos-tensorflow/vendor/armv7l/include

Name: absl_strerror
Description: Abseil strerror library
URL: https://abseil.io/
Version: 20230802
Requires: absl_config = 20230802, absl_core_headers = 20230802, absl_errno_saver = 20230802
Libs: -L${libdir}  -labsl_strerror 
Cflags: -I${includedir} -DNOMINMAX
